httpd: yum install httpd -y(RHEL Images yum httpd)
apache2: apt install apache2 -y(Ubuntu uses apache 2 apt)
App Servers:
tomcat: yum install tomcat -y(RHEL images)
tomcat9: apt install tomcat9 -y(Ubuntu images)

